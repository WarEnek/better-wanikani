{
  "manifest_version": 3,
  "name": "WaniKani Radical Header Color",
  "version": "1.0.0",
  "description": "Changes and customizes the .character-header--radical color on WaniKani.",
  "permissions": ["storage"],
  "host_permissions": ["https://www.wanikani.com/*"],
  "action": {
    "default_title": "WaniKani radical color",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.wanikani.com/subject-lessons/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
